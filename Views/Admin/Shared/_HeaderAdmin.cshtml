<header class="flex items-center justify-between bg-white shadow px-6 py-4 relative z-40">

    <!-- Left -->
    <h1 class="text-lg font-semibold text-gray-800">
        Hệ thống quản lý IT Healthy
    </h1>

    <!-- Right -->
    <div class="relative" id="menuContainer">

        <button onclick="toggleMenu()"
                class="flex items-center gap-2 text-gray-700 font-medium hover:text-green-500 transition">

            <span id="staffName">Admin</span>

            <svg id="arrowDown" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor">

                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>

        </button>

        <!-- Dropdown -->
        <div id="dropdownMenu"
             class="hidden absolute right-0 mt-3 w-52 bg-white border border-gray-200 rounded-xl shadow-xl z-50 overflow-hidden">

            <button onclick="openProfile()"
                    class="flex items-center gap-2 w-full text-left px-4 py-2.5 text-gray-700 hover:bg-indigo-50">

                Thông tin cá nhân
            </button>

            <hr>

            <a href="/Admin/Login" class="flex items-center gap-2 w-full px-4 py-2.5 text-red-600 hover:bg-red-50">
                Đăng xuất
            </a>

        </div>

    </div>

</header>


<!-- Modal Profile -->
<div id="profileModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center z-50">

    <div class="bg-gradient-to-br from-indigo-50 to-white rounded-2xl shadow-2xl p-8 w-[420px] relative">

        <!-- Close -->
        <button onclick="closeProfile()" class="absolute top-4 right-4 text-gray-500 hover:text-indigo-600">
            ✕
        </button>

        <!-- Avatar -->
        <div class="flex flex-col items-center mb-6">

            <div id="avatar"
                 class="w-20 h-20 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 text-3xl font-bold">
                A
            </div>

            <h2 id="profileName" class="text-2xl font-semibold text-indigo-700 mt-3">
                Admin
            </h2>

            <p class="text-gray-500 text-sm">
                Nhân viên tại hệ thống
            </p>

        </div>

        <!-- Info -->
        <div class="space-y-3 text-gray-700">

            <div class="flex justify-between border-b pb-2">
                <span class="font-medium">Email:</span>
                <span id="profileEmail"></span>
            </div>

            <div class="flex justify-between border-b pb-2">
                <span class="font-medium">Chức vụ:</span>
                <span id="profileRole"></span>
            </div>

            <div class="flex justify-between border-b pb-2">
                <span class="font-medium">Ngày vào làm:</span>
                <span id="profileHireDate"></span>
            </div>

        </div>

        <div class="mt-8 text-center">
            <button onclick="closeProfile()" class="px-5 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700">
                Đóng
            </button>
        </div>

    </div>

</div>

<script>

    let staff = JSON.parse(localStorage.getItem("adminInfo"));

    if (staff) {

        document.getElementById("staffName").innerText = staff.fullName;

        document.getElementById("profileName").innerText = staff.fullName;
        document.getElementById("profileEmail").innerText = staff.email;
        document.getElementById("profileRole").innerText = staff.roleStaff;

        document.getElementById("profileHireDate").innerText =
            new Date(staff.hireDate).toLocaleDateString("vi-VN");

        document.getElementById("avatar").innerText =
            staff.fullName.charAt(0).toUpperCase();
    }


    function toggleMenu() {

        let menu = document.getElementById("dropdownMenu");
        menu.classList.toggle("hidden");

    }


    function openProfile() {

        document.getElementById("profileModal").classList.remove("hidden");
        document.getElementById("dropdownMenu").classList.add("hidden");

    }


    function closeProfile() {

        document.getElementById("profileModal").classList.add("hidden");

    }

</script>