@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>ITHealthy Admin</title>

    <script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="min-h-screen flex items-center justify-center bg-cover bg-center"
      style="background-image:url('/images/bg_login.jpg')">

    <!-- overlay -->
    <div class="absolute inset-0 bg-black/30"></div>

    <!-- login card -->
    <div class="relative z-10 bg-white/90 backdrop-blur-lg rounded-3xl shadow-2xl p-8 w-[400px]">

        <div class="flex flex-col items-center mb-6">
            <h1 class="text-2xl font-bold text-indigo-700 mb-2">
                ITHealthy Admin
            </h1>

            <p class="text-gray-500 text-sm">
                Hệ thống quản trị
            </p>
        </div>

        <form method="post">

            <!-- email -->
            <div class="mb-4">
                <label class="text-gray-700 block mb-1">Email</label>

                <input
                    type="email"
                    name="email"
                    placeholder="Nhập email..."
                    required
                    class="w-full p-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:outline-none"
                />
            </div>

            <!-- password -->
            <div class="mb-4">
                <label class="text-gray-700 block mb-1">Mật khẩu</label>

                <input
                    type="password"
                    name="password"
                    placeholder="Nhập mật khẩu..."
                    required
                    class="w-full p-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:outline-none"
                />
            </div>

            <!-- remember -->
            <div class="flex items-center justify-between mb-4">
                <label class="flex items-center text-sm text-gray-600">

                    <input
                        type="checkbox"
                        name="remember"
                        class="mr-2"
                    />

                    Ghi nhớ đăng nhập
                </label>
            </div>

            <!-- login button -->
            <button
                type="submit"
                class="w-full bg-gradient-to-r from-purple-500 via-purple-400 to-purple-400 text-white font-semibold py-2 rounded-md shadow-lg hover:brightness-110 hover:scale-[1.02] transition-all duration-300"
            >
                Đăng nhập
            </button>

        </form>

        <!-- error message -->
        @if(ViewBag.Error != null)
        {
            <p class="text-red-500 text-center mt-3">
                @ViewBag.Error
            </p>
        }

        <p class="text-xs text-center text-gray-400 mt-4">
            © 2025 IT Healthy | Admin System
        </p>

    </div>

</body>
</html>