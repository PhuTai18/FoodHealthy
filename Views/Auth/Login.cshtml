@model ITHealthy.DTOs.LoginDTO

@if (!ViewData.ModelState.IsValid)
{
    <div class="mb-4 px-4 py-3 rounded-lg 
        @(ViewBag.MessageType == "error"
                     ? "bg-red-100 text-red-700 border border-red-400"
                     : "bg-yellow-100 text-yellow-700 border border-yellow-400")">

        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <p>@error.ErrorMessage</p>
        }
    </div>
}
<section class="flex min-h-screen bg-gray-50">
    @if (ViewBag.Message != null)
    {
        <div style="color: red; margin-bottom: 10px;">
            @ViewBag.Message
        </div>
    }
    <!-- LEFT: Login Form -->
    <div class="flex flex-col justify-center w-full md:w-1/2 px-8 md:px-20 bg-white shadow-lg">
        <div class="max-w-md mx-auto w-full">

            <!-- Logo -->
            <div class="mb-8 text-center">
                <div class="flex items-center justify-center mb-2">
                    <div class="bg-gradient-to-r from-green-600 via-green-500 to-teal-400 
                        text-white font-bold text-xl w-10 h-10 flex items-center 
                        justify-center rounded-md shadow-md">
                        IT
                    </div>
                </div>

                <h2 class="text-2xl font-bold text-gray-900">Đăng nhập hệ thống</h2>
                <p class="text-gray-500 text-sm mt-1">
                    Chào mừng bạn quay lại! Hãy đăng nhập để tiếp tục
                </p>
            </div>

            <!-- Form -->
            <form asp-action="Login" method="post">

                <div class="mb-4">
                    <input asp-for="Email" placeholder="Email" class="w-full px-3 py-2 border border-gray-200 rounded-md
                    focus:outline-none focus:border-green-500" />
                </div>

                <div class="mb-4 relative">
                    <input asp-for="Password" type="password" id="password" placeholder="Mật khẩu" class="w-full px-3 py-2 border border-gray-200 rounded-md
                    focus:outline-none focus:border-green-500 pr-10" />

                    <!-- Toggle Password -->
                    <span onclick="togglePassword()" class="absolute right-3 top-2.5 cursor-pointer text-gray-500">
                        👁
                    </span>
                </div>

                <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
                    <label class="flex items-center gap-2">
                        <input type="checkbox" /> Ghi nhớ đăng nhập
                    </label>

                    <a href="#" class="text-green-600 hover:underline">
                        Quên mật khẩu?
                    </a>
                </div>

                <button type="submit" class="w-full bg-gradient-to-r from-green-500 via-green-400 to-teal-400
                    text-white font-semibold py-2 rounded-md shadow-lg
                    hover:brightness-110 hover:scale-[1.02]
                    transition-all duration-300">
                    Đăng nhập
                </button>

            </form>

            <p class="text-center text-gray-500 text-sm mt-5">
                Chưa có tài khoản?
                <a asp-action="Register" class="text-green-600 font-medium">
                    Đăng ký
                </a>
            </p>

        </div>
    </div>


    <!-- RIGHT: Banner -->
    <div class="hidden md:flex w-1/2 items-center justify-center relative overflow-hidden p-12">

        <!-- Gradient -->
        <div class="absolute inset-0 bg-gradient-to-b from-blue-500 via-teal-400 to-green-400"></div>

        <!-- Background Image -->
        <img src="~/images/food-bg.png"
             class="absolute inset-0 w-full h-full object-cover opacity-30 mix-blend-overlay" />

        <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent"></div>

        <!-- Feature list -->
        <div class="relative z-10 max-w-md w-full text-white space-y-8">

            <div class="flex items-start gap-4">
                <div class="bg-white/15 p-3 rounded-lg backdrop-blur-sm text-2xl">
                    📋
                </div>
                <div>
                    <h4 class="font-semibold text-lg">Quản lý thực đơn thông minh</h4>
                    <p class="text-white/90 text-sm">
                        Giúp bạn tổ chức bữa ăn khoa học hơn
                    </p>
                </div>
            </div>

            <div class="flex items-start gap-4">
                <div class="bg-white/15 p-3 rounded-lg backdrop-blur-sm text-2xl">
                    📊
                </div>
                <div>
                    <h4 class="font-semibold text-lg">Theo dõi calo dễ dàng</h4>
                    <p class="text-white/90 text-sm">
                        Quản lý sức khỏe mỗi ngày
                    </p>
                </div>
            </div>

            <div class="flex items-start gap-4">
                <div class="bg-white/15 p-3 rounded-lg backdrop-blur-sm text-2xl">
                    💬
                </div>
                <div>
                    <h4 class="font-semibold text-lg">Giao diện thân thiện</h4>
                    <p class="text-white/90 text-sm">
                        Thiết kế hiện đại, dễ sử dụng
                    </p>
                </div>
            </div>

            <div class="flex items-start gap-4">
                <div class="bg-white/15 p-3 rounded-lg backdrop-blur-sm text-2xl">
                    ❤️
                </div>
                <div>
                    <h4 class="font-semibold text-lg">Sống khỏe mỗi ngày</h4>
                    <p class="text-white/90 text-sm">
                        Cân bằng giữa sức khỏe và công việc
                    </p>
                </div>
            </div>

        </div>

    </div>

</section>

<script>
    function togglePassword() {
        var x = document.getElementById("password");
        if (x.type === "password") {
            x.type = "text";
        } else {
            x.type = "password";
        }
    }
</script>