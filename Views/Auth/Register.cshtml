@model ITHealthy.DTOs.RegisterDTO

@if (TempData["Message"] != null)
{
    <div class="mb-4 px-4 py-3 rounded-lg 
        @(TempData["MessageType"]?.ToString() == "warning" 
            ? "bg-yellow-100 text-yellow-700 border border-yellow-400" 
            : "bg-red-100 text-red-700 border border-red-400")">
        @TempData["Message"]
    </div>
}
<section class="flex min-h-screen bg-gray-50">

    <!-- LEFT: Gradient + Feature -->
    <div class="hidden md:flex w-1/2 items-center justify-center relative overflow-hidden p-12">

        <!-- Gradient -->
        <div class="absolute inset-0 bg-gradient-to-b from-blue-500 via-teal-400 to-green-400"></div>

        <!-- Background image -->
        <img src="~/images/food-bg.png"
             class="absolute inset-0 w-full h-full object-cover opacity-30 mix-blend-overlay" />

        <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent"></div>

        <!-- Light effect -->
        <div class="absolute -right-20 -top-16 w-72 h-72 rounded-full bg-white/10 blur-3xl"></div>
        <div class="absolute -left-28 bottom-10 w-56 h-56 rounded-full bg-white/5 blur-2xl"></div>

        <!-- Feature list -->
        <div class="relative z-10 max-w-md w-full text-white space-y-8">

            <div class="flex items-start gap-4">
                <div class="bg-white/15 p-3 rounded-lg backdrop-blur-sm text-2xl">📋</div>
                <div>
                    <h4 class="font-semibold text-lg">Tạo tài khoản dễ dàng</h4>
                    <p class="text-white/90 text-sm">
                        Chỉ vài bước đơn giản để bắt đầu sử dụng hệ thống
                    </p>
                </div>
            </div>

            <div class="flex items-start gap-4">
                <div class="bg-white/15 p-3 rounded-lg backdrop-blur-sm text-2xl">📊</div>
                <div>
                    <h4 class="font-semibold text-lg">Theo dõi tiến trình</h4>
                    <p class="text-white/90 text-sm">
                        Cập nhật liên tục để cải thiện hiệu quả
                    </p>
                </div>
            </div>

            <div class="flex items-start gap-4">
                <div class="bg-white/15 p-3 rounded-lg backdrop-blur-sm text-2xl">💬</div>
                <div>
                    <h4 class="font-semibold text-lg">Hỗ trợ tận tâm</h4>
                    <p class="text-white/90 text-sm">
                        Đội ngũ luôn sẵn sàng giúp bạn
                    </p>
                </div>
            </div>

            <div class="flex items-start gap-4">
                <div class="bg-white/15 p-3 rounded-lg backdrop-blur-sm text-2xl">❤️</div>
                <div>
                    <h4 class="font-semibold text-lg">Trải nghiệm liền mạch</h4>
                    <p class="text-white/90 text-sm">
                        Giao diện thân thiện và trực quan
                    </p>
                </div>
            </div>

        </div>

    </div>


    <!-- RIGHT: Register Form -->
    <div class="flex flex-col justify-center w-full md:w-1/2 px-8 md:px-20 bg-white shadow-lg">

        <div class="max-w-md mx-auto w-full">

            <!-- Logo -->
            <div class="mb-8 text-center">
                <div class="flex items-center justify-center mb-2">
                    <div class="bg-gradient-to-r from-green-600 via-green-500 to-teal-400
                        text-white font-bold text-xl w-10 h-10 flex items-center
                        justify-center rounded-md shadow-md">
                        IT
                    </div>
                </div>

                <h2 class="text-2xl font-bold text-gray-900">Tạo tài khoản mới</h2>
                <p class="text-gray-500 text-sm mt-1">
                    Điền thông tin để bắt đầu hành trình của bạn
                </p>
            </div>


            <form asp-action="Register" method="post">

                <div class="mb-4">
                    <input asp-for="FullName" placeholder="Họ và tên"
                           class="w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:border-green-500" />
                </div>

                <div class="mb-4">
                    <input asp-for="Email" placeholder="Email"
                           class="w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:border-green-500" />
                </div>

                <div class="mb-4">
                    <input asp-for="Phone" placeholder="Số điện thoại"
                           class="w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:border-green-500" />
                </div>

                <!-- Password -->
                <div class="mb-6 relative">
                    <input asp-for="Password" type="password" id="password" placeholder="Mật khẩu"
                           class="w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:border-green-500 pr-10" />

                    <span onclick="togglePassword()" class="absolute right-3 top-2.5 cursor-pointer text-gray-500">
                        👁
                    </span>
                </div>

                <button type="submit" class="w-full bg-gradient-to-r from-green-500 via-green-400 to-teal-400
                    text-white font-semibold py-2 rounded-md shadow-lg
                    hover:brightness-110 hover:scale-[1.02]
                    transition-all duration-300">
                    Đăng ký
                </button>

            </form>

            <p class="text-center text-gray-500 text-sm mt-5">
                Đã có tài khoản?
                <a asp-action="Login" class="text-green-600 font-medium">
                    Đăng nhập
                </a>
            </p>

        </div>

    </div>

</section>


<script>
    function togglePassword() {
        var x = document.getElementById("password");
        if (x.type === "password") {
            x.type = "text";
        } else {
            x.type = "password";
        }
    }
</script>