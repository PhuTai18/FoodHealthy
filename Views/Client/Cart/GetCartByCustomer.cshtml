@model CartViewModel
@using System.Globalization

<div class="max-w-7xl mx-auto p-6">

    <!-- Header -->
    <h2 class="text-3xl font-bold mb-2">🛒 Giỏ hàng</h2>
    <p class="text-gray-500 mb-6">@Model.Items.Count sản phẩm</p>

    <!-- Alert -->
    @if (TempData["error"] != null)
    {
        <div class="bg-red-100 text-red-600 p-3 rounded mb-4">
            @TempData["error"]
        </div>
    }
    @if (TempData["success"] != null)
    {
        <div class="bg-green-100 text-green-600 p-3 rounded mb-4">
            @TempData["success"]
        </div>
    }

    @if (Model.Items.Count == 0)
    {
        <div class="text-center py-20">
            <p class="text-gray-500 text-xl mb-4">Giỏ hàng trống</p>
            <a href="/" class="bg-green-500 text-white px-6 py-3 rounded-lg">
                Mua ngay
            </a>
        </div>
    }
    else
    {
        <div class="flex flex-col lg:flex-row gap-8">

            <!-- LEFT: Product List -->
            <div class="flex-1 space-y-4">

                @foreach (var item in Model.Items)
                {
                    <div class="bg-white rounded-xl p-5 shadow-sm border hover:shadow-md transition">

                        <div class="flex gap-4">

                            <!-- Image -->
                            <div class="w-24 h-24 rounded-full overflow-hidden shadow">
                                <img src="@(item.ImageProduct ?? "/images/default.png")"         class="w-full h-full object-cover" />
                            </div>

                            <!-- Info -->
                            <div class="flex-1">

                                <h3 class="text-lg font-semibold">
                                    @(item.ProductName ?? item.ComboName ?? item.BowlName)
                                </h3>

                                <p class="text-sm text-gray-500 mb-2">
                                    @(item.DescriptionProduct ?? "Sản phẩm chất lượng cao")
                                </p>

                                <div class="flex justify-between items-center flex-wrap gap-3">

                                    <!-- Price + Quantity -->
                                    <div class="flex items-center gap-3">

                                        <p class="text-sm text-gray-500">
                                            Đơn giá: @item.UnitPrice?.ToString("c0", new CultureInfo("vi-VN"))
                                        </p>

                                        <!-- Quantity -->
                                        <div class="flex items-center bg-gray-100 rounded-lg px-2">

                                            <button onclick="updateQty(@item.CartItemId), -1)"
                                                    class="px-2 hover:text-red-500">-</button>

                                            <span class="px-3 font-semibold">
                                                @item.Quantity
                                            </span>

                                            <button onclick="updateQty(@item.CartItemId), 1)"
                                                    class="px-2 hover:text-green-500">+</button>
                                        </div>

                                    </div>

                                    <!-- Subtotal + Remove -->
                                    <div class="flex items-center gap-4">

                                        <p class="font-bold text-gray-900">
                                            @item.SubTotal.ToString("N0") ₫
                                        </p>

                                        <button onclick="removeItem(@item.CartItemId)"
                                                class="text-red-500 hover:bg-red-100 p-2 rounded">
                                            🗑
                                        </button>
                                    </div>

                                </div>

                            </div>
                        </div>
                    </div>
                }

            </div>

            <!-- RIGHT: Summary -->
            <div class="lg:w-96">

                <div class="bg-white p-6 rounded-xl shadow sticky top-24">

                    <h3 class="text-xl font-bold mb-4">Tóm tắt đơn hàng</h3>

                    <!-- Voucher -->
                    <div class="mb-4">
                        <input type="text" id="voucher"                    placeholder="Nhập mã giảm giá"
                               class="w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-green-500" />

                        <button onclick="applyVoucher()"
                                class="mt-2 w-full bg-black text-white py-2 rounded-lg hover:bg-gray-800">
                            Áp dụng
                        </button>
                    </div>

                    <!-- Price -->
                    <div class="space-y-2 border-b pb-4">

                        <div class="flex justify-between">
                            <span>Tạm tính</span>
                            <span class="font-semibold">
                                @Model.TotalPrice.ToString("N0") ₫
                            </span>
                        </div>

                        <div class="flex justify-between">
                            <span>Phí vận chuyển</span>
                            <span>Miễn phí</span>
                        </div>

                    </div>

                    <!-- Total -->
                    <div class="flex justify-between mt-4 mb-6">
                        <span class="font-bold text-lg">Tổng</span>
                        <span class="text-green-600 font-bold text-xl">
                            @Model.TotalPrice.ToString("N0") ₫
                        </span>
                    </div>

                    <!-- Checkout -->
                    <a href="/Checkout"
                           class="block text-center bg-green-500 text-white py-3 rounded-xl hover:bg-green-600 shadow-lg">
                        Thanh toán ngay →
                    </a>

                </div>

            </div>

        </div>
    }
</div>

<!-- JS -->
<script>
    function updateQty(id, delta) {
        fetch('/Cart/UpdateQuantity', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: id, delta: delta })
        }).then(() => location.reload());
    }

    function removeItem(id) {
        if (!confirm("Xóa sản phẩm?")) return;

        fetch('/Cart/Remove/' + id, {
            method: 'POST'
        }).then(() => location.reload());
    }

    function applyVoucher() {
        const code = document.getElementById("voucher").value;
        alert("Áp dụng mã: " + code); // bạn sẽ xử lý backend sau
    }
</script>