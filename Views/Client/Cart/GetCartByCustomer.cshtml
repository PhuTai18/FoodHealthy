@model CartViewModel

<h2>Giỏ hàng của bạn</h2>

@if (TempData["error"] != null)
{
    <p style="color:red">@TempData["error"]</p>
}
@if (TempData["success"] != null)
{
    <p style="color:green">@TempData["success"]</p>
}

@if (Model.Items.Count == 0)
{
    <p>Giỏ hàng trống.</p>
}
else
{
    <table border="1">
        <thead>
            <tr>
                <th>Sản phẩm</th>
                <th>Số lượng</th>
                <th>Đơn giá</th>
                <th>Tổng</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@(item.ProductName ?? item.ComboName ?? item.BowlName)</td>
                    <td>@item.Quantity</td>
                    <td>@item.UnitPrice</td>
                    <td>@item.SubTotal</td>
                </tr>
            }
        </tbody>
    </table>
    <p>Tổng tiền: @Model.TotalPrice</p>
}