@using ITHealthy.Helpers
@model List<ITHealthy.Models.Store>

@{
    ViewData["Title"] = "Stores";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="bg-[#f5f0e8] min-h-screen">

    <!-- 🔥 HEADER -->
    <div class="text-center pt-16 pb-10">
        <h1 class="text-5xl font-light text-[#5a1a3d] tracking-wide">
            ITHealthy Stores
        </h1>
        <p class="text-gray-500 mt-3">Find us near you 🌿</p>
    </div>

    <!-- 🔍 SEARCH -->
    <div class="max-w-2xl mx-auto px-6 mb-16">
        <div class="relative">
            <input id="searchBox"        type="text"        placeholder="Search by city, district..."
                   class="w-full px-6 py-4 rounded-full border border-gray-200 shadow-lg focus:outline-none focus:ring-2 focus:ring-[#5a1a3d] bg-white/80 backdrop-blur-md" />

            <span class="absolute right-5 top-1/2 -translate-y-1/2 text-gray-400">🔍</span>
        </div>
    </div>

    <!-- 🔥 STORES -->
    <div id="storeContainer">

        @for (int i = 0; i < Model.Count; i++)
        {
            var store = Model[i];
            var isReverse = i % 2 == 1;

            <div class="store-item grid md:grid-cols-2 min-h-[500px] transition duration-500" data-city="@store.City"
                 data-district="@store.District"   data-index="@i">

                <!-- IMAGE -->
                <div class="@(isReverse ? "order-2" : "order-1") relative overflow-hidden group">
                    <img src="@Url.Content($"~/images/store{(i % 3 + 1)}.jpg")"
                         class="w-full h-full object-cover transition duration-700 group-hover:scale-110" />

                    <div class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition"></div>
                </div>

                <!-- INFO -->
                <div class="@(isReverse ? "order-1" : "order-2") flex flex-col justify-center items-center text-center px-10 py-16">

                    <h1 class="text-4xl font-light text-[#5a1a3d]">ITHealthy</h1>

                    <h2 class="text-3xl font-semibold text-[#5a1a3d] mb-6">
                        @store.District
                    </h2>

                    <div class="text-xs font-bold tracking-widest text-[#5a1a3d] mb-2">
                        FIND US
                    </div>

                    <p class="text-gray-700 mb-6 max-w-md leading-relaxed">
                        @store.ToFullAddress()
                    </p>

                    <div class="text-xs font-bold tracking-widest text-[#5a1a3d] mb-2">
                        CONTACT
                    </div>

                    <p class="text-gray-700 mb-6">
                        📞 @store.Phone
                    </p>

                    <div class="flex gap-3">
                        @if (store.Latitude != null && store.Longitude != null)
                        {
                            <a target="_blank"                            href="https://www.google.com/maps?q=@store.Latitude,@store.Longitude"
                                   class="px-6 py-2 border border-[#5a1a3d] text-[#5a1a3d] rounded-full hover:bg-[#5a1a3d] hover:text-white transition">
                                View Map
                            </a>
                        }

                        <a href="/Stores/Details/@store.StoreId"
                               class="px-6 py-2 bg-[#5a1a3d] text-white rounded-full hover:opacity-90 transition">
                            Details
                        </a>
                    </div>
                </div>
            </div>
        }

    </div>

    <!-- EMPTY -->
    <div id="noResult" class="hidden text-center text-gray-400 py-20 text-lg">
        No stores found 😢
    </div>

    <div class="h-20"></div>
</div>

<!-- 🔥 SCRIPT -->
<script>
    const searchBox = document.getElementById("searchBox");
    const stores = document.querySelectorAll(".store-item");
    const noResult = document.getElementById("noResult");

    function showDefault() {
        stores.forEach((store, index) => {
            if (index < 3) {
                store.style.display = "grid";
            } else {
                store.style.display = "none";
            }
        });
    }

    showDefault();

    searchBox.addEventListener("input", function () {
        const keyword = this.value.toLowerCase();
        let visible = 0;

        if (keyword === "") {
            showDefault();
            noResult.classList.add("hidden");
            return;
        }

        stores.forEach(store => {
            const city = store.dataset.city.toLowerCase();
            const district = store.dataset.district.toLowerCase();

            if (city.includes(keyword) || district.includes(keyword)) {
                store.style.display = "grid";
                visible++;
            } else {
                store.style.display = "none";
            }
        });

        if (visible === 0) {
            noResult.classList.remove("hidden");
        } else {
            noResult.classList.add("hidden");
        }
    });
</script>