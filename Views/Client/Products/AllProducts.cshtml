@model List<ITHealthy.DTOs.ProductDTO>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var categories = ViewBag.Categories as List<ITHealthy.Models.Category>;
}

<div class="min-h-screen pb-16 scroll-smooth pt-24">

    <!-- 🔥 CATEGORY BAR -->
    <div class="fixed left-0 right-0 top-20 z-50">
        <div class="flex justify-center p-4">
            <div class="flex gap-4 bg-green-200 rounded-full px-4 py-2 shadow-md flex-wrap">

                @foreach (var cat in categories)
                {
                    <button onclick="scrollToCategory(@cat.CategoryId)"
                            class="px-4 py-2 rounded-full font-semibold text-[#3E0D1C] hover:bg-[#FFF6E5] transition">
                        @cat.CategoryName.ToUpper()
                    </button>
                }

            </div>
        </div>
    </div>

    <!-- 🔥 CONTENT -->
    <div class="max-w-7xl mx-auto flex flex-col gap-16 px-6">

        @foreach (var cat in categories)
        {
            var products = Model.Where(p => p.CategoryId == cat.CategoryId).ToList();

            <section id="cat-@cat.CategoryId" class="scroll-mt-32">

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

                    <!-- 🔥 BANNER -->
                    <div class="group relative rounded-3xl overflow-hidden shadow-md lg:col-span-2 hover:shadow-xl transition">

                        <img src="@(cat.ImageCategories ?? "/images/default-banner.png")"
                             class="w-full h-full object-cover brightness-90 group-hover:scale-105 transition duration-500" />

                        <div class="absolute inset-0 bg-black/30 flex flex-col justify-center items-center text-white text-center">
                            <h2 class="text-4xl font-bold mb-2">
                                @cat.CategoryName
                            </h2>
                            <p>@cat.DescriptionCat</p>
                        </div>
                    </div>

                    <!-- 🔥 PRODUCTS -->
                    @foreach (var p in products)
                    {
                        <a href="/products/@p.ProductId">

                            <div class="group relative flex flex-col items-center bg-[#fff8f0] rounded-3xl p-5 shadow-md hover:shadow-xl transition">

                                <!-- ❤️ -->
                                <div class="absolute top-4 left-4 z-20 w-10 h-10 flex items-center justify-center rounded-full"
                                     style="background-color:#ff623e;color:#f5edd8;">
                                    <svg xmlns="http://www.w3.org/2000/svg"             fill="currentColor" viewBox="0 0 24 24"
                                         class="w-6 h-6">
                                        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 
                                        2 6 3.5 4 5.5 4c1.54 0 3.04.99 3.57 2.36h1.87C13.46 4.99 
                                        14.96 4 16.5 4 18.5 4 20 6 20 8.5c0 3.78-3.4 6.86-8.55 
                                        11.54L12 21.35z" />
                                    </svg>
                                </div>

                                <!-- IMAGE -->
                                <div class="w-full flex justify-center mb-4">
                                    <img src="@p.ImageProduct"                       class="w-48 h-48 object-contain rounded-full bg-white p-4 
                                    transition duration-500 group-hover:-translate-y-3 group-hover:scale-110" />
                                </div>

                                <!-- NAME + CAL -->
                                <div class="flex justify-between items-center w-full mb-2">
                                    <h3 class="text-xl font-bold text-[#3E0D1C]">
                                        @p.ProductName
                                    </h3>

                                    @if (p.Calories != null)
                                    {
                                        <span class="text-sm border px-3 py-1 rounded-full">
                                            @p.Calories kcal
                                        </span>
                                    }
                                </div>

                                <!-- DESC -->
                                <p class="text-gray-700 text-sm mb-3 text-center min-h-[40px]">
                                    @p.DescriptionProduct
                                </p>

                                <!-- DOT LINE -->
                                <div class="w-full h-[2px] mb-2"
                                     style="background-image: radial-gradient(gray 2px, transparent 2px); background-size: 10px 4px;">
                                </div>

                                <!-- NUTRITION -->
                                <div class="flex justify-around w-full text-[#3E0D1C] font-semibold mb-4">
                                    <div class="text-center">
                                        <div>@(p.Protein ?? 0)</div>
                                        <small class="text-gray-500">PROTEIN</small>
                                    </div>
                                    <div class="text-center">
                                        <div>@(p.Carbs ?? 0)</div>
                                        <small class="text-gray-500">CARBS</small>
                                    </div>
                                    <div class="text-center">
                                        <div>@(p.Fat ?? 0)</div>
                                        <small class="text-gray-500">FAT</small>
                                    </div>
                                </div>

                                <!-- PRICE -->
                                <div class="flex items-center justify-between w-full mt-auto">
                                    <span class="text-xl font-bold text-[#ff623e]">
                                        @((p.BasePrice ?? 0).ToString("N0")) đ
                                    </span>

                                    <button onclick="event.preventDefault(); addToCart(@p.ProductId, @p.BasePrice)"
                                            class="w-10 h-10 flex items-center justify-center bg-[#ff623e] text-white rounded-full hover:bg-[#e55734]">
                                        +
                                    </button>
                                </div>

                            </div>

                        </a>
                    }

                    @if (!products.Any())
                    {
                        <p class="col-span-full text-center text-gray-500">
                            Chưa có sản phẩm
                        </p>
                    }

                </div>

            </section>
        }

    </div>

</div>

<!-- 🔥 SCRIPT SCROLL -->
<script>
    function scrollToCategory(id) {
        const el = document.getElementById("cat-" + id);
        if (el) {
            el.scrollIntoView({ behavior: "smooth" });
        }
    }
</script>