@model IEnumerable<ITHealthy.DTOs.ProductDTO>

@{
    ViewData["Title"] = "Danh sách sản phẩm";
}

<h2>Danh sách sản phẩm</h2>

@{
    var categories = ViewBag.Categories as List<ITHealthy.Models.Category>;
}

<div class="mb-3">

    <span class="fw-bold">Danh mục:</span>

    <a asp-action="AllProducts"     class="btn btn-sm btn-secondary">
        Tất cả
    </a>

    @foreach (var cate in categories)
    {
        <a asp-action="AllProducts"         asp-route-categoryId="@cate.CategoryId"         class="btn btn-sm btn-outline-primary">

            @cate.CategoryName
        </a>
    }

</div>

<a asp-action="Create" class="btn btn-primary">Thêm sản phẩm</a>

<br />
<br />

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<table class="table table-bordered table-striped">

    <thead>
        <tr>
            <th>ID</th>
            <th>Hình ảnh</th>
            <th>Tên sản phẩm</th>
            <th>Danh mục</th>
            <th>Giá</th>
            <th>Calories</th>
            <th>Protein</th>
            <th>Carbs</th>
            <th>Fat</th>
            <th>Trạng thái</th>
            <th width="200">Hành động</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.ProductId</td>

                <td>
                    @if (!string.IsNullOrEmpty(item.ImageProduct))
                    {
                        <img src="@item.ImageProduct" width="80" />
                    }
                </td>

                <td>@item.ProductName</td>

                <td>@item.CategoryName</td>

                <td>@item.BasePrice</td>

                <td>@item.Calories</td>

                <td>@item.Protein</td>

                <td>@item.Carbs</td>

                <td>@item.Fat</td>

                <td>
                    @if (item.IsAvailable == true)
                    {
                        <span class="badge bg-success">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Unavailable</span>
                    }
                </td>

                <td>

                    <a asp-action="GetProductById"       asp-route-id="@item.ProductId"       class="btn btn-info btn-sm">
                        Chi tiết
                    </a>

                    <a asp-action="UpdateProduct"                   asp-route-id="@item.ProductId"                    class="btn btn-warning btn-sm">
                        Sửa
                    </a>

                    <a asp-action="DeleteProduct"        asp-route-id="@item.ProductId"        class="btn btn-danger btn-sm">
                        Xóa
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>