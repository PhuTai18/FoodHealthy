<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FoodHealthy</title>

    <!-- 🔥 Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- 🔥 Swiper CSS (PHẢI TRÊN CSS custom) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

    <!-- 🔥 CSS -->
    <link href="~/css/site.css" rel="stylesheet" />
    <link href="~/css/home.css" rel="stylesheet" />
    <link href="~/css/Navbar.css" rel="stylesheet" />
    <link href="~/css/ImageCardGallery.css" rel="stylesheet" />
    <link href="~/css/ImageAdv.css" rel="stylesheet" />

</head>

<body class="bg-[#F5EDD8]">

    <!-- 🔥 NAVBAR -->
    @await Html.PartialAsync("_Navbar")

    <!-- 🔥 CONTENT -->
    <main class="pt-24">
        @RenderBody()
    </main>

    <!-- 🔥 FOOTER -->
    @await Html.PartialAsync("_Footer")

    <!-- 🔥 LIB JS (ĐỂ CUỐI BODY) -->
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

    <!-- 🔥 GLOBAL SCRIPT -->
    <script>
        const navbar = document.getElementById("navbar");
        const submenu = document.getElementById("submenu");
        const userDropdown = document.getElementById("userDropdown");

        // SCROLL NAVBAR
        window.addEventListener("scroll", function () {
            if (!navbar) return;

            if (window.scrollY > 50) {
                navbar.classList.add("navbar-scrolled");
                navbar.classList.remove("navbar-transparent");
            } else {
                navbar.classList.add("navbar-transparent");
                navbar.classList.remove("navbar-scrolled");
            }
        });

        // SUBMENU
        function toggleSubmenu() {
            if (!submenu) return;
            submenu.classList.toggle("submenu-open");
            submenu.classList.toggle("submenu-closed");
        }

        // USER DROPDOWN
        function toggleUserMenu() {
            if (!userDropdown) return;
            userDropdown.classList.toggle("hidden");
        }

        // CLICK OUTSIDE
        document.addEventListener("click", function (e) {
            if (!e.target.closest(".user-menu-wrapper")) {
                if (userDropdown) userDropdown.classList.add("hidden");
            }
        });
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>