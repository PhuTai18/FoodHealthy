@using ITHealthy.DTOs
@inject ITHealthy.Services.Admin.IStaffService StaffService

<h2 class="text-2xl font-bold mb-4">Quản lý nhân viên</h2>

<div class="mb-4 flex justify-between items-center">
    <span class="text-gray-600">Total: @staffs.Count</span>

    <button type="button"
            class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg shadow"
            @onclick="OpenCreate">
        + Thêm nhân viên
    </button>
</div>

<table class="w-full bg-white rounded-xl shadow overflow-hidden">
    <thead class="bg-gray-100">
        <tr class="text-left text-sm text-gray-600">
            <th class="p-3">Avatar</th>
            <th class="p-3">Tên</th>
            <th class="p-3">Email</th>
            <th class="p-3">Phone</th>
            <th class="p-3">Role</th>
            <th class="p-3">Trạng thái</th>
            <th class="p-3">Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var s in staffs)
        {
            <tr class="border-t hover:bg-gray-50">
                <td class="p-3">
                    <img src="@(string.IsNullOrEmpty(s.Avatar) ? "/images/default-avatar.png" : s.Avatar)"
                         class="w-10 h-10 rounded-full object-cover" />
                </td>

                <td class="p-3 font-medium">@s.FullName</td>
                <td class="p-3">@s.Email</td>
                <td class="p-3">@s.Phone</td>
                <td class="p-3">@s.Role</td>

                <td class="p-3">
                    <span class="px-2 py-1 rounded text-xs @(s.IsActive ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700")">
                        @(s.IsActive ? "Active" : "Inactive")
                    </span>
                </td>

                <td class="p-3 space-x-2">
                    <button type="button"
                            class="text-yellow-600"
                            @onclick="() => EditStaff(s)">
                        Edit
                    </button>

                    <button type="button"
                            class="text-red-600"
                            @onclick="() => ConfirmDelete(s.StaffId)">
                        Delete
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (loading)
{
    <p class="mt-4 text-gray-500">Loading...</p>
}

<!-- 🔥 MODAL -->
@if (showModal)
{
    <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-[9999]">

        <div class="bg-white p-6 rounded-xl w-[400px] shadow-lg">

            <h3 class="text-xl font-bold mb-4">
                @(isEdit ? "Cập nhật nhân viên" : "Thêm nhân viên")
            </h3>

            <input class="w-full border p-2 mb-2 rounded"
                   placeholder="Tên"
                   @bind="form.FullName" />

            <input class="w-full border p-2 mb-2 rounded"
                   placeholder="Email"
                   @bind="form.Email" />

            <input class="w-full border p-2 mb-2 rounded"
                   placeholder="Phone"
                   @bind="form.Phone" />

            <input class="w-full border p-2 mb-2 rounded"
                   placeholder="Role"
                   @bind="form.RoleStaff" />

            <input class="w-full border p-2 mb-4 rounded"
                   placeholder="Password"
                   @bind="form.PasswordHash" />

            <div class="flex justify-end space-x-2">
                <button type="button"
                        class="px-4 py-2 bg-gray-300 rounded"
                        @onclick="CloseModal">
                    Cancel
                </button>

                <button type="button"
                        class="px-4 py-2 bg-indigo-600 text-white rounded"
                        @onclick="Save">
                    Save
                </button>
            </div>

        </div>
    </div>
}

<!-- DELETE CONFIRM -->
@if (showDelete)
{
    <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-[9999]">

        <div class="bg-white p-6 rounded-xl shadow w-[300px] text-center">

            <p class="mb-4">Xác nhận xoá?</p>

            <button type="button"
                    class="bg-red-600 text-white px-4 py-2 rounded mr-2"
                    @onclick="Delete">
                Xoá
            </button>

            <button type="button"
                    class="bg-gray-300 px-4 py-2 rounded"
                    @onclick="() => showDelete = false">
                Huỷ
            </button>

        </div>
    </div>
}

@code {

    List<StaffResponseDTO> staffs = new();

    bool loading = true;

    bool showModal = false;
    bool isEdit = false;

    bool showDelete = false;
    int deleteId;

    StaffRequestDTO form = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    async Task LoadData()
    {
        loading = true;

        staffs = await StaffService.GetAllAsync();

        loading = false;

        StateHasChanged();
    }

    void OpenCreate()
    {
        form = new StaffRequestDTO();
        isEdit = false;
        showModal = true;
    }

    void EditStaff(StaffResponseDTO s)
    {
        form = new StaffRequestDTO
        {
            StaffId = s.StaffId,
            FullName = s.FullName,
            Email = s.Email,
            Phone = s.Phone,
            RoleStaff = s.Role
        };

        isEdit = true;
        showModal = true;
    }

    void CloseModal()
    {
        showModal = false;
    }

    async Task Save()
    {
        if (isEdit)
        {
            await StaffService.UpdateAsync(form.StaffId.Value, form);
        }
        else
        {
            await StaffService.CreateAsync(form);
        }

        showModal = false;

        await LoadData();
    }

    void ConfirmDelete(int id)
    {
        deleteId = id;
        showDelete = true;
    }

    async Task Delete()
    {
        await StaffService.DeleteAsync(deleteId);

        showDelete = false;

        await LoadData();
    }

    
}